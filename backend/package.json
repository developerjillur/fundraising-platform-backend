{
  "name": "fundraising-backend",
  "version": "1.0.0",
  "description": "NestJS backend for The Last McDonald's Burger fundraising platform",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
